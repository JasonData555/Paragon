# Admin password as bcrypt hash (rounds=12)
# Generate: node -e "const b=require('bcrypt'); b.hash('YOUR_PASSWORD',12).then(console.log)"
ADMIN_PASSWORD_HASH=

# Set to "true" locally to enable admin write operations (upload/delete)
# Do NOT set in Vercel production — writes won't persist in serverless environment
ALLOW_WRITES=true

# Base URL for PDF asset loading (Inter fonts, Hitch logo)
# Local: http://localhost:3000
# Production: https://your-vercel-domain.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000
